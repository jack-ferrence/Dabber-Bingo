{
  "appId": "com.dobber.bingo",
  "appName": "Dobber",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 500,
      "backgroundColor": "#0c0c14",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0c0c14"
    }
  }
}
