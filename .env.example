# ─── Client-side (Vite) ───────────────────────────────────────────
# These are embedded in the browser bundle via import.meta.env.
# Only use the ANON (public) key here — never the service role key.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ENV=development
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# RevenueCat — powers iOS in-app purchases for the /contribute flow
# Get your Apple API key at https://app.revenuecat.com
VITE_REVENUECAT_APPLE_KEY=appl_your_revenuecat_apple_api_key

# ─── Server-side only (Netlify Functions) ─────────────────────────
# These are NEVER sent to the browser. In production, set them in
# the Netlify dashboard (Site Settings > Environment Variables).
# For local dev with `netlify dev`, put real values in .env.local
# (which is .gitignored).

SUPABASE_URL=https://your-project.supabase.co
# ⚠️  NEVER commit a real service role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stats source: "espn" for live data, "mock" for random test data
STATS_SOURCE=mock

# TheOddsAPI — powers odds-based bingo card generation
# Get a free key at https://the-odds-api.com
ODDS_API_KEY=your_the_odds_api_key_here

# Sentry error monitoring (server-side)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Stripe — powers the /contribute donation flow (web only)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# RevenueCat webhook secret — used to verify iOS IAP webhook calls
# Set in RevenueCat dashboard → Integrations → Webhooks → Authorization header
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret
