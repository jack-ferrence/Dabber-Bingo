# ─── Client-side (Vite) ───────────────────────────────────────────
# These are embedded in the browser bundle. Only use the ANON (public) key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ENV=development
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Server-side only (Netlify Functions) ─────────────────────────
# These are NEVER sent to the browser. In production, set them in
# the Netlify dashboard (Site Settings > Environment Variables).
SUPABASE_URL=https://your-project.supabase.co
# ⚠️  NEVER commit a real service role key. In production, set this
# ONLY in the Netlify dashboard. For local Netlify dev, use .env.local
# (which is .gitignored).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stats source: "espn" for live NBA data, "mock" for random test data
STATS_SOURCE=mock

# TheOddsAPI — powers odds-based bingo card generation for NBA games
# Get a free key at https://the-odds-api.com
ODDS_API_KEY=your_the_odds_api_key_here

# Sentry error monitoring (server-side)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
